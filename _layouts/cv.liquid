---
layout: default
---
{% unless site.data.resume %}
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">
        {{ page.title }}
        {% if page.cv_pdf %}
          <a
            href="{{ page.cv_pdf | prepend: 'assets/pdf/' | relative_url}}"
            target="_blank"
            rel="noopener noreferrer"
            class="float-right"
            ><i class="fa-solid fa-file-pdf"></i
          ></a>
        {% endif %}
      </h1>
      {% if page.description %}
        <p class="post-description">{{ page.description }}</p>
      {% endif %}
    </header>

    <div class="clearfix">
    {{ content }}
    </div>

   
  </div>

<div style="width: 100%; height: 800px;">
  {% if page.cv_pdf %}
  <iframe src="{{ page.cv_pdf | prepend: 'assets/pdf/' | relative_url }}" 
          width="100%" 
          height="800">
    Your browser does not support iframes. Please click on the icon at the top right to download my CV.
  </iframe>
  {% endif %}
</div>
# {% endunless %}
